<Window x:Class="PDFSplitterforCopilot.OpenAIApiSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenAI API Settings"
        Height="380"
        Width="560"
        MinHeight="360"
        MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F9F9F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="OpenAI API Settings"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Name="txtStatus"
                   TextWrapping="Wrap"
                   Foreground="#605E5C"
                   Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox Name="txtApiKey"
                         Height="36"
                         Padding="8,6"/>
            <TextBlock Text="Leave blank to keep the existing saved key. Environment variables are used first when present."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#605E5C"
                       Margin="0,6,0,16"/>

            <TextBlock Text="Model" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Name="txtModel"
                     Height="36"
                     Padding="8,6"/>
            <TextBlock Text="Default: gpt-4o-mini"
                       FontSize="12"
                       Foreground="#605E5C"
                       Margin="0,6,0,0"/>
        </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Clear key"
                    Width="86"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="ClearKey_Click"/>
            <Button Content="Cancel"
                    Width="78"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Width="78"
                    Height="32"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
